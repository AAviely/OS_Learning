{
  "version": 3,
  "configurePresets": [
    {
      "name": "gcc-ninja",
      "displayName": "GCC + Ninja",
      "description": "Using GCC compiler with Ninja build system",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_SHARED_LIBS": "ON"
      }
    }
  ]
}