# Put this in the root of your project
CompileFlags:
  Add: [-std=c++20, -Wall]

Index:
  Background: Build

Diagnostics:
  # This stops clangd from suggesting or auto-inserting headers
  UnusedIncludes: None

Config:
  # This is the "Nuclear" option for auto-insertion
  Completion:
    AllScopes: true
  Hover:
    ShowPath: true

# THE MOST IMPORTANT PART:
InlayHints:
  Enabled: No

# This tells clangd NOT to mess with your includes
# when you use a symbol from a header you haven't included yet.
Style:
  HeaderInsertion: Never